#!/bin/sh
ref="${1:-main}"
git ls-tree -r --name-only "$ref" | grep '/Dockerfile$' | while read f; do
  info=$(git log -1 --format='%s %at' "$ref" -- "$f")
  parsed=$(echo "$info" | sed -n 's/.*\[\(bitnami\/\)\?\([^]]*\)\] Release \([^ ]*\) (.* \([0-9]*\)$/\2 \3 \4/p')
  [ -n "$parsed" ] && echo "$f $parsed"
done
