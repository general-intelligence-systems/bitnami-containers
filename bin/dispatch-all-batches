#!/bin/sh
set -e

total=$(wc -l < data/last-12-month-images.txt)
groups=$(( (total + 255) / 256 ))

echo "Dispatching $groups groups ($total images, 256 per group)..."

for group in $(seq 1 $groups); do
  echo "Dispatching group $group/$groups..."
  gh workflow run build-historic-batch.yml -f group="$group" --ref where-the-magic-happens
  sleep 2
done

echo "All $groups groups dispatched."
